---
import heroData from '../content/hero/hero.json';
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src={heroData.backgroundImage}
      alt="ToToT Background"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-primary/70 via-primary/50 to-transparent"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto animate-slideInBounce">
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 drop-shadow-lg">
      {heroData.headline}
    </h1>
    <p class="text-xl md:text-2xl text-white/90 mb-8 drop-shadow-md">
      {heroData.tagline}
    </p>
    <a
      href={heroData.ctaLink}
      class="inline-block bg-accent text-white px-8 py-4 rounded-lg text-lg font-semibold
             hover:bg-accent-blue hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl"
    >
      {heroData.ctaText}
    </a>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
