---
import mascotData from '../content/mascot/mascot.json';
---

{mascotData.active && (
  <div id="mascot-container" class="fixed bottom-8 right-8 z-40 animate-float">
    <button
      id="mascot-button"
      class="relative bg-white rounded-full p-4 shadow-2xl hover:scale-110 transition-transform duration-300 cursor-pointer"
      aria-label="Mascot"
    >
      <span class="text-5xl">{mascotData.character}</span>

      <!-- Tooltip -->
      <div
        id="mascot-tooltip"
        class="hidden absolute bottom-full right-0 mb-4 bg-primary text-white p-4 rounded-lg shadow-xl w-64 animate-slideInBounce"
      >
        <p class="text-sm leading-relaxed whitespace-pre-line">
          {mascotData.tooltip}
        </p>
        <div class="absolute bottom-0 right-8 transform translate-y-1/2 rotate-45 w-3 h-3 bg-primary"></div>
      </div>
    </button>
  </div>
)}

<script>
  const mascotButton = document.getElementById('mascot-button');
  const mascotTooltip = document.getElementById('mascot-tooltip');

  let isTooltipVisible = false;

  mascotButton?.addEventListener('click', () => {
    isTooltipVisible = !isTooltipVisible;

    if (isTooltipVisible) {
      mascotTooltip?.classList.remove('hidden');
    } else {
      mascotTooltip?.classList.add('hidden');
    }
  });

  // Close tooltip when clicking outside
  document.addEventListener('click', (e) => {
    if (!mascotButton?.contains(e.target as Node) && isTooltipVisible) {
      mascotTooltip?.classList.add('hidden');
      isTooltipVisible = false;
    }
  });
</script>
